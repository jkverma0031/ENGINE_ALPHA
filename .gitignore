# ==============================================================================
# ENGINE_ALPHA - .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. ENGINE_ALPHA Specific Data & Artifacts (DO NOT TRACK)
# ------------------------------------------------------------------------------
# We ignore the heavy data files, model weights, and databases to keep the repo fast.

# Raw and Cleaned Datasets
datasets/*.csv
datasets/*.parquet
extras/*.csv
extras/*.json

# Live Database History
database/*.db
database/*.sqlite3
database/*.sqlite

# Serialized Model Artifacts (PyTorch weights, XGBoost rules, Scalers)
artifacts/**/*.pt
artifacts/**/*.pth
artifacts/**/*.json
artifacts/**/*.pkl
artifacts/**/*.joblib

# Execution and Telemetry Logs
logs/*.log
logs/*.txt

# ------------------------------------------------------------------------------
# 2. Python & Environment Environments
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual Environments
venv/
env/
.venv/
miniconda3/

# Environment Variables (Secrets)
.env
.env.local

# Jupyter Notebook Checkpoints (If you use them for testing)
.ipynb_checkpoints/

# ------------------------------------------------------------------------------
# 3. OS & IDE Generated Files
# ------------------------------------------------------------------------------
# Mac
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# IDEs
.vscode/
.idea/
*.swp
*.swo

# ------------------------------------------------------------------------------
# 4. Exceptions (Files we DO want to track inside ignored folders)
# ------------------------------------------------------------------------------
# If you add a script inside extras/ or database/ that needs tracking, un-ignore it here.
!extras/web_scraper.py
!database/schema_setup.sql